{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://pltlrmyzqiitsxggxven.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "tacticaltracker-mcp",
      "version": "0.1.0",
      "title": "TacticalTracker (Tactical Chaos)"
    },
    "tools": [
      {
        "name": "list_matches",
        "title": "List matches",
        "description": "List the team's recent CS2 matches (map, rival, score, date, type). Most recent first.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "default": 10,
              "description": "How many matches to return (max 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "match_type": {
              "description": "Filter by match type.",
              "type": "string",
              "enum": [
                "OFFICIAL",
                "TRAINING"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_match_stats",
        "title": "Get match stats",
        "description": "Get one match with per-player stats (kills, deaths, ADR, KAST, rating).",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "match_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The match UUID (from list_matches)."
            }
          },
          "required": [
            "match_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_upcoming_events",
        "title": "List upcoming agenda events",
        "description": "List upcoming training sessions, tacticals, and team events from the agenda.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "days_ahead": {
              "default": 14,
              "description": "How many days into the future to look.",
              "type": "integer",
              "minimum": 1,
              "maximum": 90
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_team_members",
        "title": "List team members",
        "description": "List the current CS2 roster (player name, steam tag, role, whether they're a coach).",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "include_coaches": {
              "default": true,
              "description": "Include coaches in the result.",
              "type": "boolean"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_agenda_event",
        "title": "Create agenda event",
        "description": "Add a new event to the team agenda (training, tactical, match, meeting). Requires user approval.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1,
              "description": "Event title."
            },
            "date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "Date in YYYY-MM-DD (team local time)."
            },
            "time_start": {
              "type": "string",
              "pattern": "^\\d{2}:\\d{2}$",
              "description": "Start time HH:MM (24h)."
            },
            "time_end": {
              "type": "string",
              "pattern": "^\\d{2}:\\d{2}$",
              "description": "End time HH:MM (24h)."
            },
            "event_type": {
              "default": "training",
              "type": "string",
              "enum": [
                "training",
                "tactical",
                "match",
                "meeting",
                "other"
              ]
            },
            "description": {
              "default": "",
              "type": "string"
            }
          },
          "required": [
            "title",
            "date",
            "time_start",
            "time_end"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
